# Database (MySQL on Railway)
DATABASE_URL="mysql://user:password@host:port/database"

# JWT Authentication
# IMPORTANT: Generate secure secrets with: openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS"
JWT_REFRESH_SECRET="REPLACE_WITH_GENERATED_SECRET_MIN_32_CHARS"

# SMTP Email (cPanel)
SMTP_HOST="mail.insomniatattoo.ro"
SMTP_PORT=465
SMTP_USER="contact@insomniatattoo.ro"
SMTP_PASS="your-email-password"
# Use "dry-run" in local/e2e runs to log email intents without SMTP delivery.
EMAIL_DELIVERY_MODE="smtp"

# App
NEXT_PUBLIC_SITE_URL="https://insomniatattoo.ro"
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-api-key"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb=your-embed-id"

# Seed
SEED_ADMIN_PASSWORD="change-this-to-a-strong-password"

# Google OAuth (from Google Cloud Console)
# IMPORTANT: Both variables must have the SAME value
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Admin email for notifications
ADMIN_EMAIL="admin@insomniatattoo.ro"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# Sentry Monitoring (optional, recommended for production)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_RELEASE=""

# CSP violation reporting (optional, production)
# CSP_REPORT_URI="https://your-collector.example/csp-report-endpoint"
# CSP_REPORT_TO="https://your-collector.example/csp-report-endpoint"

# Vercel Blob Storage (auto-provisioned from Vercel Dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=""

# Upload
MAX_FILE_SIZE=5242880

# Studio Contact Info
NEXT_PUBLIC_STUDIO_EMAIL="contact@insomniatattoo.ro"
NEXT_PUBLIC_STUDIO_PHONE="+40 XXX XXX XXX"

# Social Links
NEXT_PUBLIC_SOCIAL_INSTAGRAM="https://instagram.com/insomniatattoo"
NEXT_PUBLIC_SOCIAL_TIKTOK="https://tiktok.com/@insomniatattoo"
NEXT_PUBLIC_SOCIAL_FACEBOOK="https://facebook.com/insomniatattoo"

# Web Push (VAPID keys - generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@insomniatattoo.ro"

# Cron Jobs (Vercel Cron secret)
CRON_SECRET=""
