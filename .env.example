# Database (MySQL on cPanel)
DATABASE_URL="mysql://user:password@localhost:3306/insomnia_tattoo"

# JWT Authentication
JWT_SECRET="your-very-long-random-secret-key-here-min-32-chars"
JWT_REFRESH_SECRET="another-very-long-random-secret-key-here"

# SMTP Email (cPanel)
SMTP_HOST="mail.insomniatattoo.ro"
SMTP_PORT=465
SMTP_USER="contact@insomniatattoo.ro"
SMTP_PASS="your-email-password"

# App
NEXT_PUBLIC_SITE_URL="https://insomniatattoo.ro"
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your-google-maps-api-key"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb=your-embed-id"

# Seed
SEED_ADMIN_PASSWORD="change-this-password"

# Analytics (optional)
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# Upload
UPLOAD_DIR="./public/uploads"
MAX_FILE_SIZE=5242880
